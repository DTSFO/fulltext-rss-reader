# Copy this file to .env for the normal Docker Compose deployment.
# Replace every value marked "replace". Never commit the resulting .env file.

# Public application origin and loopback listener
NODE_ENV=production
APP_URL=https://rss.example.com
APP_PORT=18120

# PostgreSQL (use URL-safe hexadecimal or alphanumeric credentials)
POSTGRES_DB=fulltext-rss-reader
POSTGRES_USER=fulltext-rss-reader
POSTGRES_PASSWORD=replace-with-a-long-random-url-safe-password

# Fixed-user authentication
SINGLE_USER_USERNAME=replace-with-your-username
# Keep the Argon2 hash single-quoted so Compose treats dollar signs literally.
SINGLE_USER_PASSWORD_HASH='$argon2id$replace-with-pnpm-hash-password-output'
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Feed refresh and extraction
FEED_REFRESH_MINUTES=30
REFRESH_BATCH_SIZE=4
FULL_TEXT_PREFETCH_COUNT=3

# Normal self-hosting must keep demo limits disabled.
DEMO_MODE=false
