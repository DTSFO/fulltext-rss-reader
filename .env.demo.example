# Copy to .env.demo and replace every value marked "replace".
# Keep the Argon2 hash single-quoted so Compose treats dollar signs literally.

DEMO_APP_URL=https://rss-demo.example.com
DEMO_APP_PORT=18121
DEMO_IMAGE_TAG=local

DEMO_POSTGRES_DB=fulltext-rss-reader-demo
DEMO_POSTGRES_USER=fulltext-rss-reader-demo
DEMO_POSTGRES_PASSWORD=replace-with-a-long-random-database-password

DEMO_USERNAME=demo-user
# Public shared-demo password shown on the login page: demo-reader
DEMO_PASSWORD_HASH='$argon2id$replace-with-pnpm-hash-password-output'
DEMO_SESSION_SECRET=replace-with-at-least-32-random-bytes

# The hosted demo intentionally has no background worker.
# These values still bound manual refresh/extraction work performed by the web app.
DEMO_FEED_REFRESH_MINUTES=60
DEMO_REFRESH_BATCH_SIZE=2
DEMO_FULL_TEXT_PREFETCH_COUNT=1
DEMO_MAX_FEEDS=5
DEMO_MAX_THEMES=3
DEMO_MAX_ARTICLES_PER_FEED=50
DEMO_FEED_CREATE_COOLDOWN_MINUTES=1
DEMO_REFRESH_COOLDOWN_MINUTES=10
