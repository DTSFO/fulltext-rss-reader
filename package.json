{
  "name": "fulltext-rss-reader",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "next dev",
    "demo:dev": "vite --config vite.demo.config.ts",
    "demo:build": "vite build --config vite.demo.config.ts",
    "demo:config": "docker compose --env-file .env.demo.example -f docker-compose.demo.yml config --quiet",
    "build": "pnpm build:web && pnpm build:worker && pnpm build:migrate",
    "build:web": "next build",
    "build:worker": "tsup src/jobs/refresh-worker.ts --format esm --platform node --out-dir dist/jobs --clean --no-splitting",
    "build:migrate": "tsup src/db/migrate.ts --format esm --platform node --out-dir dist/db --no-splitting",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:watch": "vitest",
    "test:e2e": "pnpm test:e2e:mock && pnpm test:e2e:ssr",
    "test:e2e:mock": "node scripts/run-mock-e2e.mjs",
    "test:e2e:ssr": "node scripts/run-ssr-e2e.mjs",
    "hash-password": "tsx scripts/hash-password.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "NODE_OPTIONS=--conditions=react-server tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "worker": "NODE_OPTIONS=--conditions=react-server tsx src/jobs/refresh-worker.ts",
    "safety": "node scripts/check-public-safety.mjs"
  },
  "dependencies": {
    "@asamuzakjp/css-color": "^5.1.11",
    "@csstools/css-tokenizer": "^4.0.0",
    "@mozilla/readability": "^0.6.0",
    "@node-rs/argon2": "^2.0.2",
    "@streamparser/json": "^0.0.22",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.10.0",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.6",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
