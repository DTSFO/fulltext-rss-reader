# Application
NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgres://fulltext-rss-reader:fulltext-rss-reader@localhost:5432/fulltext-rss-reader

# Local Docker Compose PostgreSQL only. Production uses .env.production.example.
POSTGRES_DB=fulltext-rss-reader
POSTGRES_USER=fulltext-rss-reader
POSTGRES_PASSWORD=fulltext-rss-reader

# Fixed-user authentication
SINGLE_USER_USERNAME=demo-user
SINGLE_USER_PASSWORD_HASH='$argon2id$replace-with-a-real-hash'
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Feed refresh and extraction
FEED_REFRESH_MINUTES=30
REFRESH_BATCH_SIZE=4
FULL_TEXT_PREFETCH_COUNT=3

# Optional hosted demo limits (ignored unless DEMO_MODE=true)
DEMO_MODE=false
DEMO_MAX_FEEDS=5
DEMO_MAX_THEMES=3
DEMO_MAX_ARTICLES_PER_FEED=50
DEMO_FEED_CREATE_COOLDOWN_MINUTES=1
DEMO_REFRESH_COOLDOWN_MINUTES=10
